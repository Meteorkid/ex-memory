# ===== LLM 配置 =====
# OpenAI 兼容 API（硅基流动、DeepSeek、OpenAI、任意兼容端点）
# 如果未设置 LLM_API_KEY，会自动回退到 DEEPSEEK_API_KEY 环境变量
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.8
LLM_TOP_P=0.9
LLM_FREQUENCY_PENALTY=0.6

# 硅基流动示例：
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_MODEL=deepseek-ai/DeepSeek-V3

# ===== Embedding 配置 =====
# 与 LLM 可以用不同的服务商
# 未配置时 RAG 检索功能不可用，但对话仍可正常进行
EMBEDDING_API_KEY=your_api_key_here
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3

# ===== 安全配置 =====
# CORS 允许的来源（逗号分隔），生产环境请替换为实际域名
CORS_ORIGINS=http://localhost:8000,http://localhost:7860

# ===== 日志配置 =====
# LOG_LEVEL=INFO
# LOG_FORMAT=text  # text | json（json 格式输出结构化日志）
